  <Text>k__BackingField: "\u0418\u0433\u043D\u043E\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u043F\u0440\u043E\u0442\u043E\u043A\u043E\u043B\u043E\u0432 \u0432\u0435\u0434\u0435\u0442
    \u043A \u0448\u0442\u0440\u0430\u0444\u0430\u043C. \u0412\u044B \u0433\u043E\u0442\u043E\u0432\u044B
    \u043E\u043F\u043B\u0430\u0442\u0438\u0442\u044C \u043F\u0440\u043E\u0445\u043E\u0434
    \u044D\u043D\u0435\u0440\u0433\u0438\u0435\u0439 \u0438\u043B\u0438 \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u0435\u0439?"
  <Answers>k__BackingField:
  - <Text>k__BackingField: "\u0417\u0430\u0431\u0438\u0440\u0430\u0439 \u044D\u043D\u0435\u0440\u0433\u0438\u044E,
      \u0443 \u043C\u0435\u043D\u044F \u0435\u0451 \u043F\u043E\u043B\u043D\u043E"
    <NextMessage>k__BackingField: {fileID: 11400000, guid: eb06b574ed9ae5b428c4d2097eec1cbf, type: 2}
  - <Text>k__BackingField: "\u041C\u043E\u044F \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u044F
      \u0438 \u0442\u0430\u043A \u043D\u0430 \u0434\u043D\u0435, \u043C\u043D\u0435
      \u043F\u043B\u0435\u0432\u0430\u0442\u044C"
    <NextMessage>k__BackingField: {fileID: 11400000, guid: 5e402ecaaa56c8448b2e818dbbbf230e, type: 2}
