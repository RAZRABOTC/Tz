  <Text>k__BackingField: "\u0420\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u044F
    \u043E\u0431\u043D\u0443\u043B\u0435\u043D\u0430. \u0422\u0435\u043F\u0435\u0440\u044C
    \u043C\u0443\u0441\u043E\u0440 \u0431\u0443\u0434\u0435\u0442 \u0437\u043B\u0438\u0442\u044C\u0441\u044F
    \u043D\u0430 \u0432\u0430\u0441 \u0438 \u043B\u0435\u0442\u0435\u0442\u044C \u0431\u044B\u0441\u0442\u0440\u0435\u0435.
    \u0413\u043E\u0442\u043E\u0432\u044B?"
  <Answers>k__BackingField:
  - <Text>k__BackingField: "\u041F\u0443\u0441\u0442\u044C \u043B\u0435\u0442\u0438\u0442,
      \u044F \u0432\u0441\u0435\u0445 \u0440\u0430\u0441\u0441\u043E\u0440\u0442\u0438\u0440\u0443\u044E!"
    <NextMessage>k__BackingField: {fileID: 11400000, guid: 581f763ad65f7c64b9d17ddcbff257ae, type: 2}
  - <Text>k__BackingField: "\u0412 \u0441\u043C\u044B\u0441\u043B\u0435 \"\u0437\u043B\u0438\u0442\u044C\u0441\u044F\"?
      \u042D\u0442\u043E \u0436\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0431\u0430\u043D\u043A\u0438!"
    <NextMessage>k__BackingField: {fileID: 11400000, guid: eb13d7817bb2a514b8cacad9261c5ce7, type: 2}
