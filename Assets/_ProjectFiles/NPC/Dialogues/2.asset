  m_EditorClassIdentifier: Assembly-CSharp::DialogueMessage
  <Text>k__BackingField: "\u042D\u0439, \u0442\u044B! \u0412\u044B\u0433\u043B\u044F\u0434\u0438\u0448\u044C
    \u043A\u0430\u043A \u0442\u043E\u0442, \u043A\u0442\u043E \u043D\u0435 \u0431\u043E\u0438\u0442\u0441\u044F
    \u0438\u0441\u043F\u0430\u0447\u043A\u0430\u0442\u044C \u0440\u0443\u043A\u0438.
    \u041F\u043E\u043C\u043E\u0436\u0435\u0448\u044C \u043C\u043D\u0435 \u0434\u043E\u0441\u0442\u0430\u0442\u044C
    \u043E\u0434\u043D\u0443 \u0432\u0435\u0449\u0438\u0446\u0443?"
  <Answers>k__BackingField:
  - <Text>k__BackingField: "\u0421\u043C\u043E\u0442\u0440\u044F \u0447\u0442\u043E
      \u043D\u0443\u0436\u043D\u043E \u0441\u0434\u0435\u043B\u0430\u0442\u044C"
    <NextMessage>k__BackingField: {fileID: 11400000, guid: 08d5daf62ea256145a8527c5e824942c, type: 2}
  - <Text>k__BackingField: "\u0415\u0441\u043B\u0438 \u0437\u0430 \u044D\u0442\u043E
